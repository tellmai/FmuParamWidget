QWidget#ParamSetWidget {
    background: #f5f5f5;
    color: #4a4a4a;
    font-family: "Microsoft YaHei UI", "Microsoft YaHei", "Segoe UI";
    font-size: 14px;
}

QScrollArea#ParamSetScrollArea {
    border: none;
    background: #f5f5f5;
}

QWidget#ParamSetContent {
    background: #f5f5f5;
}

QWidget#ModuleSummary {
    min-height: 98px;
    max-height: 98px;
    background: #f5f5f5;
    border-bottom: 1px solid #9b9b9b;
}

QLabel#ModuleImageBox {
    min-width: 136px;
    max-width: 136px;
    min-height: 64px;
    max-height: 64px;
    background: #e2e2e2;
    border: 1px solid #b8b8b8;
    color: #4f4f4f;
    font-size: 14px;
}

QLabel#ModuleName {
    color: #4a4a4a;
    font-size: 14px;
    font-weight: 500;
}

QTextEdit#ModuleDescription {
    border: none;
    background: transparent;
    color: #666666;
    font-size: 13px;
    selection-background-color: #cfe1ff;
}

QWidget#ParamCategoryWidget {
    background: #f5f5f5;
    border: none;
}

QWidget#CategoryHeader {
    min-height: 28px;
    max-height: 28px;
    background: #eeeeee;
    border-top: 1px solid #999999;
    border-bottom: 1px solid #bcbcbc;
}

QLabel#CategoryTitle {
    color: #333333;
    font-size: 14px;
    font-weight: 400;
}

QToolButton#CategoryArrow {
    border: none;
    background: transparent;
    padding: 0;
}

QWidget#CategoryContent {
    background: #f5f5f5;
}

QWidget#SecondCategoryPlaceholder {
    background: #2f80ed;
    min-height: 220px;
}

QWidget#ButtonBar {
    min-height: 58px;
    max-height: 58px;
    background: #f5f5f5;
    border-top: 1px solid #d7d7d7;
}

QPushButton {
    min-width: 78px;
    min-height: 24px;
    max-height: 24px;
    border: 1px solid #d0d0d0;
    border-radius: 3px;
    background: #ffffff;
    color: #4d4d4d;
    font-size: 14px;
    padding: 0 16px;
}

QPushButton:hover {
    background: #f7f7f7;
    border-color: #bdbdbd;
}

QPushButton:pressed {
    background: #ececec;
}

QPushButton#PrimaryButton {
    background: #3f63b5;
    border-color: #3f63b5;
    color: #ffffff;
}

QPushButton#PrimaryButton:hover {
    background: #3559aa;
    border-color: #3559aa;
}

QPushButton#PrimaryButton:pressed {
    background: #2d4d96;
    border-color: #2d4d96;
}

QScrollBar:horizontal,
QScrollBar:vertical {
    background: #ffffff;
    border: none;
    margin: 0;
}

QScrollBar:horizontal {
    height: 8px;
}

QScrollBar:vertical {
    width: 8px;
}

QScrollBar::handle:horizontal {
    background: #e1e1e1;
    border-radius: 4px;
    margin: 2px 0;
    min-width: 24px;
}

QScrollBar::handle:vertical {
    background: #e1e1e1;
    border-radius: 4px;
    margin: 0 2px;
    min-height: 24px;
}

QScrollBar::add-line,
QScrollBar::sub-line {
    width: 0;
    height: 0;
}

QScrollBar::add-page,
QScrollBar::sub-page {
    background: #ffffff;
}
